{
  "plugins": {
    "dream": {
      "enabled": true,
      "settings": {
        "triggers": ["/dream", "做梦"]
      },
      "groups": {
        "allow": ["*"],
        "deny": []
      }
    },
    "image": {
      "enabled": true,
