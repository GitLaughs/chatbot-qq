# Copy to /etc/chatbot-qq.env on the server and chmod 600.
# This file is shared by cc-connect-qq.service and onebot-group-proxy.service.

# OneBot / NapCat upstream exposed only on localhost.
ONEBOT_UPSTREAM_URL=ws://127.0.0.1:3001
ONEBOT_PROXY_PORTS=3002,3003,3004,3005
ONEBOT_LISTEN_PORT=3002
ONEBOT_AT_PORT=3003

# Replace with the QQ groups this bot is allowed to process.
ONEBOT_ALLOWED_GROUPS=REPLACE_WITH_GROUP_ID_1,REPLACE_WITH_GROUP_ID_2

# QQ emoji id used as the lightweight "working on it" reaction.
ONEBOT_ACK_EMOJI_ID=76

# Passive listen gating. selective records all messages but only lets cc-connect
# answer when a message looks like it needs the bot or matches member profile notes.
ONEBOT_LISTEN_TRIGGER_MODE=selective
ONEBOT_LISTEN_TRIGGER_KEYWORDS=bot,机器人,助手,codex,qqbot,qq bot,帮我,帮忙,能不能,可以帮,求助,看看,看一下,分析,总结,建议,怎么,为什么,咋,如何,是否,是不是,吗,？,?,报错,错误,失败,修一下,改一下,代码,脚本,实验,作业,报告
ONEBOT_PROFILE_REPLY_MARKERS=触发回复,需要回复,关注点,未解决,重要信息

# Exact group messages that run the local dream command instead of entering cc-connect.
ONEBOT_DREAM_COMMAND_ENABLED=1
ONEBOT_DREAM_TRIGGERS=/dream,做梦
ONEBOT_DREAM_TIMEOUT_MS=900000

# Exact group messages that generate an image and send it back as a QQ image.
# API secrets must be set only in this ignored server env file, not in git.
ONEBOT_IMAGE_COMMAND_ENABLED=1
ONEBOT_IMAGE_TRIGGERS=/画图,/生图,/img,画图,生图
ONEBOT_IMAGE_TIMEOUT_MS=600000
ONEBOT_IMAGE_API_MODE=auto
ONEBOT_IMAGE_MODEL=gpt-5.5
ONEBOT_IMAGE_IMAGES_MODEL=gpt-image-1
ONEBOT_IMAGE_SIZE=1024x1024
ONEBOT_IMAGE_QUALITY=medium
ONEBOT_IMAGE_OUTPUT_FORMAT=png
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=replace-me

# QQ Codex provider routing. Keep Feishu/OpenClaw provider config separate.
QQ_PROVIDER_PRIMARY_NAME=qq-opentoken
QQ_PROVIDER_FALLBACK_NAME=qq-mimo-fallback
QQ_PROVIDER_SOURCE=cc-switch-second-balance
QQ_OPENTOKEN_BASE_URL=https://otokapi.com
# QQ_OPENTOKEN_API_KEY=replace-me
# Optional: comma-separated OpenToken keys to count. If only one healthy key
# remains, QQ falls back to Mimo while Feishu can keep using the high-balance key.
# QQ_OPENTOKEN_POOL_KEYS=replace-me-low,replace-me-high
QQ_OPENTOKEN_MIN_BALANCE=1
QQ_OPENTOKEN_MIN_HEALTHY_KEYS=2
# Optional provider balance endpoint. Without this, the checker only tests /v1/models.
# QQ_OPENTOKEN_BALANCE_URL=https://otokapi.com/api/user/self
QQ_MIMO_PROXY_BASE_URL=http://127.0.0.1:18081/v1
QQ_MIMO_PROXY_API_KEY=qq-local-mimo

# Optional, must match NapCat access_token if enabled.
# ONEBOT_ACCESS_TOKEN=
