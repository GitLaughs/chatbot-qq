# Copy to /etc/chatbot-qq.env on the server and chmod 600.
# This file is shared by cc-connect-qq.service and onebot-group-proxy.service.

# OneBot / NapCat upstream exposed only on localhost.
ONEBOT_UPSTREAM_URL=ws://127.0.0.1:3001
ONEBOT_PROXY_PORTS=3002,3003,3005,3006,3007,3008,3009,3011,3012,3013
ONEBOT_LISTEN_PORT=3002
ONEBOT_AT_PORT=3003
ONEBOT_HEALTH_HOST=127.0.0.1
ONEBOT_HEALTH_PORT=3010
ONEBOT_PROXY_STATE_FILE=/opt/chatbot-qq/.cc-connect/onebot-proxy-state.json
ONEBOT_NAPCAT_DATA_DIR=/opt/chatbot-qq/deploy/linux/napcat-data/NapCat
ONEBOT_OUTGOING_RETRY_MAX=2
ONEBOT_OUTGOING_RESPONSE_TIMEOUT_MS=12000
ONEBOT_OUTGOING_RETRY_BASE_DELAY_MS=1200
ONEBOT_PENDING_FILE_RETRY_DELAY_MS=4000

# Long answers and formula-heavy replies are rendered to PNG before sending.
# Linux deployments need ImageMagick `convert` and a CJK font such as fonts-noto-cjk.
ONEBOT_RENDER_IMAGEMAGICK_SCRIPT=/opt/chatbot-qq/scripts/render-qq-card-imagemagick.js
ONEBOT_IMAGEMAGICK_CONVERT=convert
ONEBOT_RENDER_FONT=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
ONEBOT_RENDER_MAX_HEIGHT=1200

# Runtime retention. Cleanup runs daily through chatbot-qq-cleanup.timer.
CHATBOT_QQ_LOG_KEEP_DAYS=14
CHATBOT_QQ_GENERATED_KEEP_DAYS=30
CHATBOT_QQ_ARCHIVE_KEEP_DAYS=90

# Replace with the QQ groups this bot is allowed to process.
ONEBOT_ALLOWED_GROUPS=123456789,234567890,345678901
ONEBOT_AT_ONLY_GROUPS=234567890
ONEBOT_GROUP_ROUTES=123456789:3002:3003,234567890::3005,345678901:3012:3013
ONEBOT_ALLOWED_PRIVATE_USERS=100000002,100000003,100000004,100000005,100000001
ONEBOT_PRIVATE_ROUTES=100000002:3006,100000003:3007,100000004:3008,100000005:3009,100000001:3011
# Optional. If set, high-impact commands such as /模式, /安静, /恢复 require sender user_id in this list.
ONEBOT_ADMIN_USERS=100000001
ONEBOT_ADMIN_ROOT_USERS=100000001
# Users that receive a QQ poke action when their private message reaches this proxy.
# Group messages never trigger this poke ACK.
ONEBOT_ADMIN_POKE_ACK_USERS=100000001

# QQ emoji id used as the lightweight "working on it" reaction.
ONEBOT_ACK_EMOJI_ID=76

# Passive listen gating. selective records all messages but only lets cc-connect
# answer when a message looks like it needs the bot or matches member profile notes.
ONEBOT_LISTEN_TRIGGER_MODE=selective
ONEBOT_LISTEN_TRIGGER_KEYWORDS=bot,机器人,助手,codex,qqbot,qq bot,帮我,帮忙,能不能,可以帮,求助,看看,看一下,分析,总结,建议,怎么,为什么,咋,如何,是否,是不是,吗,？,?,报错,错误,失败,修一下,改一下,代码,脚本,实验,作业,报告
ONEBOT_MINIMAL_LISTEN_GROUPS=345678901
ONEBOT_MINIMAL_LISTEN_KEYWORDS=bot,机器人,助手,codex,qqbot,qq bot,写不完作业
ONEBOT_PROFILE_REPLY_MARKERS=触发回复,需要回复,关注点,未解决,重要信息

# Intelligence upgrade. Deterministic local state only; no per-message LLM work.
ONEBOT_CONTINUITY_ENABLED=1
ONEBOT_CONTINUITY_GAP_MINUTES=30
ONEBOT_CONTINUITY_MESSAGE_LIMIT=10
ONEBOT_MOOD_ENABLED=1
ONEBOT_MOOD_HISTORY_LIMIT=10
ONEBOT_ENERGY_WINDOW_MS=300000
ONEBOT_FEEDBACK_ENABLED=1
ONEBOT_FEEDBACK_WINDOW_SECONDS=300
ONEBOT_PROACTIVE_ENABLED=1
ONEBOT_PROACTIVE_LEVEL=normal
ONEBOT_PROACTIVE_COOLDOWN_MS=900000
ONEBOT_PROACTIVE_CHECKIN_HOURS=4
ONEBOT_PROACTIVE_CHECKIN_INTERVAL_MS=1800000

# Exact group messages that run the local dream command instead of entering cc-connect.
ONEBOT_DREAM_COMMAND_ENABLED=1
ONEBOT_DREAM_TRIGGERS=/dream,做梦
ONEBOT_DREAM_TIMEOUT_MS=900000

# Natural-language task agent. Model parsing makes task understanding broad;
# deterministic fallbacks remain available when the parser command is unset.
QQ_TASK_TIMEZONE=Asia/Shanghai
# Optional parser command: reads one JSON request from stdin and prints task spec JSON.
# Example command: node /opt/chatbot-qq/scripts/task-model-parser-bridge.js
# QQ_TASK_MODEL_PARSER_COMMAND=
QQ_TASK_MODEL_PARSER_MODEL=gpt-5.4
QQ_TASK_MODEL_PARSER_MODE=responses
QQ_TASK_MODEL_PARSER_TIMEOUT_MS=8000
QQ_TASK_MODEL_PARSER_HTTP_TIMEOUT_MS=30000
# Optional local executors for file/script tasks. Leave unset to delegate to cc-connect.
# Example command for both: node /opt/chatbot-qq/scripts/artifact-model-bridge.js
# QQ_TASK_FILE_MODIFIER_COMMAND=
QQ_TASK_FILE_MODIFIER_TIMEOUT_MS=10000
# QQ_TASK_SCRIPT_GENERATOR_COMMAND=
QQ_TASK_SCRIPT_GENERATOR_TIMEOUT_MS=10000
QQ_TASK_ARTIFACT_MODEL=gpt-5.4
QQ_TASK_ARTIFACT_MODEL_MODE=responses
QQ_TASK_ARTIFACT_MODEL_HTTP_TIMEOUT_MS=60000
QQ_TASK_ARTIFACT_MODEL_MAX_OUTPUT_TOKENS=4096
# Optional deploy/restart executor. Confirmation is still required before it runs.
# Example command: bash /opt/chatbot-qq/scripts/confirmed-qq-task-deploy.sh
# QQ_TASK_DEPLOY_COMMAND=
QQ_TASK_DEPLOY_TIMEOUT_MS=300000
# Optional health command after deploy/restart; should exit non-zero on failure.
# Example command: bash /opt/chatbot-qq/scripts/confirmed-qq-task-health.sh
# QQ_TASK_DEPLOY_HEALTH_COMMAND=
QQ_TASK_DEPLOY_HEALTH_TIMEOUT_MS=120000

# Scheduled profile updater. chatbot-qq-profile-update.timer runs every 3 hours.
CHATBOT_QQ_PROFILE_UPDATE_MODEL=gpt-5.5
CHATBOT_QQ_PROFILE_UPDATE_REASONING_EFFORT=medium
CHATBOT_QQ_PROFILE_UPDATE_LOOKBACK_HOURS=72
CHATBOT_QQ_EVIDENCE_MAX_CHARS=12000
CHATBOT_QQ_EVIDENCE_MAX_ITEMS_PER_KIND=8
CHATBOT_QQ_EVIDENCE_MAX_TEXT_CHARS=220
CHATBOT_QQ_EVIDENCE_KEEP_DAYS=30
CHATBOT_QQ_JSONL_SHARD_MAX_BYTES=2097152

# Exact group messages that generate an image and send it back as a QQ image.
# API secrets must be set only in this ignored server env file, not in git.
ONEBOT_IMAGE_COMMAND_ENABLED=1
ONEBOT_IMAGE_TRIGGERS=/画图,/生图,/img,画图,生图
ONEBOT_IMAGE_TIMEOUT_MS=600000
ONEBOT_IMAGE_API_MODE=auto
ONEBOT_IMAGE_KEY_POOL_MAX=4
ONEBOT_IMAGE_MAX_CONCURRENT_PER_GROUP=4
ONEBOT_IMAGE_QUEUE_MAX_PER_GROUP=20
ONEBOT_IMAGE_MODEL=gpt-5.5
ONEBOT_IMAGE_IMAGES_MODEL=gpt-image-1
ONEBOT_IMAGE_SIZE=1024x1024
ONEBOT_IMAGE_QUALITY=medium
ONEBOT_IMAGE_OUTPUT_FORMAT=png
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=replace-me
# OPENAI_IMAGE_API_KEYS=key1,key2,key3,key4
# OPENAI_IMAGE_BASE_URLS=https://api.openai.com/v1,https://api.openai.com/v1,https://api.openai.com/v1,https://api.openai.com/v1

# QQ Codex provider routing. Keep Feishu/OpenClaw provider config separate.
QQ_PROVIDER_PRIMARY_NAME=qq-opentoken
QQ_PROVIDER_FALLBACK_NAME=qq-mimo-fallback
QQ_PROVIDER_SOURCE=cc-switch-highest-balance
QQ_OPENTOKEN_BASE_URL=https://otokapi.com
# QQ_OPENTOKEN_API_KEY=replace-me
# Optional: comma-separated OpenToken keys. QQ selects the healthy key with the
# highest remaining balance; it does not reserve the highest-balance key for Feishu.
# QQ_OPENTOKEN_POOL_KEYS=qq-key-placeholder,feishu-key-placeholder
QQ_OPENTOKEN_MIN_BALANCE=20
QQ_OPENTOKEN_MIN_HEALTHY_KEYS=1
# Provider failover checks a minimal /responses request by default, because
# /v1/models can stay healthy while generation returns 5xx.
QQ_OPENTOKEN_GENERATION_HEALTH_ENABLED=1
QQ_OPENTOKEN_HEALTH_MODEL=gpt-5.4-mini
QQ_OPENTOKEN_RESPONSES_PATH=/responses
QQ_OPENTOKEN_GENERATION_HEALTH_TIMEOUT=40
# Optional provider balance endpoint.
# QQ_OPENTOKEN_BALANCE_URL=https://otokapi.com/api/user/self
QQ_MIMO_PROXY_BASE_URL=http://127.0.0.1:18081/v1
QQ_MIMO_PROXY_API_KEY=qq-local-mimo

# Optional, must match NapCat access_token if enabled.
# ONEBOT_ACCESS_TOKEN=
